OPENAI_API_KEY=

# Optional Kafka/Redpanda live stream mode.
# Leave KAFKA_ENABLED unset/false to use the built-in WebSocket simulator fallback.
KAFKA_ENABLED=false
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_SENSOR_TOPIC=aria.sensor-readings
LIVE_INTERVAL_MS=1000
LIVE_SCENARIO=normal

# Optional critical alert email notifications.
# For Gmail, use an app password for SMTP_PASS rather than your account password.
ALERT_EMAIL_TO=madumita240912@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL_COOLDOWN_MS=300000
